{
    "name": "pico/settings",
    "description": "A Laravel package for key-value settings, supporting user-specific and model-specific configurations.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Robin Khan",
            "email": "sk118420@gmail.com"
        }
    ],
    "keywords": ["laravel", "settings", "configuration", "key-value"],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/cache": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Pico\\Settings\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Pico\\Settings\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Pico\\Settings\\SettingsServiceProvider"
            ],
            "aliases": {
                "Settings": "Pico\\Settings\\Facades\\Settings"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/pest"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
